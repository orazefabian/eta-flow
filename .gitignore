# dependencies
node_modules/

# build output — the bundle is committed so HACS can load the plugin from the
# repo (dist/<filename>); the release workflow also attaches a fresh copy.
dist/*
!dist/eta-flow-card.js

# caches / logs
*.log
npm-debug.log*
.eslintcache
.DS_Store

# editor
.vscode/
.idea/

# local HA dev config (except reference)
config/*
!config/configuration.yaml
